<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">
    <RelativeLayout
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="SOS紧急联系人"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="暂无紧急联系人，请填写"
        android:textColor="#e5000000"
        android:layout_marginTop="32dp"
        android:textSize="20sp"
        android:layout_marginLeft="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_gravity="center_vertical"
        android:layout_marginLeft="32dp"
        android:background="@drawable/bg_gray_personal_radius_shape"
        android:layout_marginRight="32dp"
        android:gravity="center_vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="姓名"
            android:textColor="#e5000000"
            android:textSize="14sp"
            android:layout_marginLeft="24dp"/>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:textColor="#ff181818"
            android:singleLine="true"
            android:textSize="16sp"
            android:background="@null"
            android:padding="15dp"
            android:maxLines="1"
            android:lines="1"
            android:hint="请填写"
            android:layout_marginLeft="32dp"
            android:gravity="end"
            android:layout_marginRight="24dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_vertical"
        android:layout_marginLeft="32dp"
        android:background="@drawable/bg_gray_personal_radius_shape"
        android:layout_marginRight="32dp"
        android:gravity="center_vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关系"
            android:textColor="#e5000000"
            android:textSize="14sp"
            android:layout_marginLeft="24dp"/>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etRelationship"
            android:layout_width="match_parent"
            android:textColor="#ff181818"
            android:textSize="16sp"
            android:background="@null"
            android:singleLine="true"
            android:padding="15dp"
            android:hint="请填写"
            android:maxLines="1"
            android:layout_marginLeft="32dp"
            android:gravity="end"
            android:layout_marginRight="24dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_vertical"
        android:layout_marginLeft="32dp"
        android:background="@drawable/bg_gray_personal_radius_shape"
        android:layout_marginRight="32dp"
        android:gravity="center_vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手机号"
            android:textColor="#e5000000"
            android:textSize="14sp"
            android:layout_marginLeft="24dp"/>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etTel"
            android:layout_width="match_parent"
            android:textColor="#ff181818"
            android:textSize="16sp"
            android:background="@null"
            android:inputType="phone"
            android:padding="15dp"
            android:hint="请填写"
            android:singleLine="true"
            android:maxLines="1"
            android:layout_marginLeft="32dp"
            android:gravity="end"
            android:layout_marginRight="24dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnOk"
        android:layout_width="match_parent"
        android:text="保存"
        android:textColor="#ffffffff"
        android:textSize="16sp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:layout_marginTop="43dp"
        android:background="@drawable/selector_next_btn"
        android:layout_height="wrap_content"/>
</LinearLayout>