<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical">

    <ImageView
        android:layout_width="match_parent"
        android:src="@drawable/bg_one_key_large"
        android:scaleType="centerCrop"
        android:layout_height="match_parent"/>

    <View
        android:id="@+id/statusBarView"
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <RelativeLayout
        android:visibility="visible"
        android:layout_below="@+id/statusBarView"
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_back_white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="掌上挪车"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_alignTop="@+id/titleLayout"
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_height="match_parent">

        <RelativeLayout
            android:visibility="visible"
            android:layout_width="0dp"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginLeft="20dp"
            android:layout_marginBottom="30dp"
            android:layout_gravity="bottom"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivCircleLeft"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_one_key_outer"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_alignTop="@+id/ivCircleLeft"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_one_key_arrow"/>

            <ImageView
                android:layout_width="wrap_content"
                android:rotation="180"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="4dp"
                android:layout_alignBottom="@+id/ivCircleLeft"
                android:src="@drawable/ic_one_key_arrow"/>

            <com.shenghao.widget.JoystickView
                android:id="@+id/joystickLeft"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:directionType="vertical"
                android:layout_centerInParent="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_gravity="top"
            android:layout_marginTop="40dp"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/view"
                android:layout_width="1dp"
                android:layout_centerInParent="true"
                android:layout_height="1dp"/>

<!--            <ImageView-->
<!--                android:src="@drawable/ic_one_car_circle"-->
<!--                android:layout_width="198dp"-->
<!--                android:layout_marginTop="20dp"-->
<!--                android:background="#55ff0000"-->
<!--                android:layout_height="198dp"/>-->

            <ImageView
                android:id="@+id/ivCar"
                android:layout_width="wrap_content"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_one_key_shan"
                android:layout_height="wrap_content"/>

            <ImageView
                android:layout_centerInParent="true"
                android:layout_width="wrap_content"
                android:src="@drawable/ic_one_key_car"
                android:layout_height="wrap_content"/>

        </RelativeLayout>


        <RelativeLayout
            android:layout_width="0dp"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="30dp"
            android:layout_gravity="bottom"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivCircleRight"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_one_key_outer"/>

            <ImageView
                android:rotation="270"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="-4dp"
                android:layout_alignStart="@+id/ivCircleRight"
                android:src="@drawable/ic_one_key_arrow"/>

            <ImageView
                android:layout_width="wrap_content"
                android:rotation="90"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginRight="-4dp"
                android:layout_alignEnd="@+id/ivCircleRight"
                android:src="@drawable/ic_one_key_arrow"/>

            <com.shenghao.widget.JoystickView
                android:id="@+id/joystickRight"
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:directionType="horizontal"
                android:layout_centerInParent="true"/>

        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>