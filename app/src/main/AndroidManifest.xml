        <activity android:name=".ui.SeatControlActivity" />
        <activity android:name=".ui.SosActivity" />
        <activity android:name=".ui.WindowControlActivity" />
        <activity android:name=".ui.ChargeActivity" />
        <activity android:name=".ui.BleActivity"
            android:exported="true">
