<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="#ff262f4c" />
            <corners android:topLeftRadius="8dp" android:topRightRadius="8dp" android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp" />
        </shape>
    </item>
    <item android:state_checked="true">
        <layer-list>

            <!-- 阴影层 -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#ff00c3ff" />
                    <corners android:radius="10dp" />
                </shape>
            </item>

            <!-- 前景层 -->
            <item
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FF231702" />
                    <stroke
                        android:width="1dp"
                        android:color="#FFFFB915" />
                    <corners android:radius="8dp" />
                </shape>
            </item>

        </layer-list>
    </item>
</selector>