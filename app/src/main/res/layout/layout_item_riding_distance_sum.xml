<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:background="@drawable/bg_white_radius_shape"
    android:padding="20dp">

    <ImageView
        android:layout_width="wrap_content"
        android:src="@drawable/ic_ride_distance_sum"
        android:layout_height="wrap_content"/>
    
    <TextView
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="@string/riding_total_mileage"
        android:layout_marginLeft="15dp"
        android:textColor="#ff181818"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/ridingAllDistanceLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/ridingAllDistanceTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF181818"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="234.4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:text="km"
            android:textColor="#FF181818"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>