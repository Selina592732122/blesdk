<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF6F6F8"
    android:orientation="vertical">

    <ImageView
        android:layout_width="match_parent"
        android:src="@drawable/bg_battery"
        android:layout_height="304dp"/>

    <View
        android:id="@+id/statusBarView"
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <RelativeLayout
        android:layout_below="@+id/statusBarView"
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/battery_info"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_below="@+id/titleLayout"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        android:layout_height="match_parent">

        <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <LinearLayout
                android:layout_marginLeft="32dp"
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <com.shenghao.widget.VerticalProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="40dp"
                    android:layout_height="142dp"/>

                <TextView
                    android:id="@+id/tvPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60%"
                    android:textStyle="bold"
                    android:textColor="#ff181818"
                    android:textSize="36sp"
                    android:layout_marginTop="24dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remaining_power"
                    android:textColor="#99000000"
                    android:textSize="12sp"
                    />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivCar"
                android:layout_alignParentEnd="true"
                android:layout_width="256dp"
                android:layout_height="170dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_item_vehicle"/>


        </RelativeLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_margin="24dp"
            android:visibility="visible"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:background="@drawable/bg_white_radius_shape"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/cycle_count"
                    android:drawableStart="@drawable/ic_charge_green"
                    android:drawablePadding="10dp"
                    android:textColor="#99000000"
                    android:textSize="14sp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvTimes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="54"
                    android:textColor="#e6000000"
                    android:textSize="24sp"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/times_unit"
                    android:textColor="#e6000000"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:background="@drawable/bg_white_radius_shape"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/battery_temperature"
                    android:drawableStart="@drawable/ic_charge_yellow"
                    android:drawablePadding="10dp"
                    android:textColor="#99000000"
                    android:textSize="14sp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvTemper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textColor="#e6000000"
                    android:textSize="24sp"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/temperature_unit"
                    android:textColor="#e6000000"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:background="@drawable/bg_white_radius_shape"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_power_consumption"
                    android:drawableStart="@drawable/ic_charge_light_blue"
                    android:drawablePadding="10dp"
                    android:textColor="#99000000"
                    android:textSize="14sp"
                    android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvPower"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="54"
                    android:textColor="#e6000000"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/percent_unit"
                    android:textColor="#e6000000"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:background="@drawable/bg_white_radius_shape"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/battery_health"
                    android:drawableStart="@drawable/ic_charge_blue"
                    android:drawablePadding="10dp"
                    android:textColor="#99000000"
                    android:textSize="14sp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvHealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="89"
                    android:textColor="#e6000000"
                    android:textSize="24sp"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="%"
                    android:textColor="#e6000000"
                    android:textSize="14sp"
                    />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>