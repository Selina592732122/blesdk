                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/vehicle_positioning"
                            android:textColor="#FF181818"
                            android:textSize="14sp"
                            android:drawablePadding="4dp"
                            android:drawableStart="@drawable/ic_main_location"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/gpsTimeTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:textColor="#99000000"
                            android:textSize="12sp"
                            tools:text="2024-04-01 22:37" />

                        <ImageView
                            android:id="@+id/gpsRefreshIv"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginLeft="5dp"
                            android:padding="3dp"
                            android:src="@drawable/ic_refresh_location" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1px"
                            android:layout_weight="1" />

                    </LinearLayout>

                    <!-- 地图 -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/vehicleMapContainer"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            app:cardCornerRadius="4dp"
                            app:cardElevation="0dp">

                            <com.amap.api.maps.MapView
                                android:id="@+id/vehicleMapView"
                                android:layout_width="match_parent"
                                android:layout_height="150dp" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="8dp"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/gpsBtn"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@drawable/ic_terminal_location" />

                            <ImageView
                                android:id="@+id/locationBtn"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@drawable/ic_user_location" />

                        </LinearLayout>
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/gpsAddressTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:background="@drawable/bg_gray_04_radius4_shape"
                        android:textColor="#E6000000"
                        android:textSize="12sp"
                        tools:text="浙江省杭州市西湖风景区" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvControl"
                    android:drawablePadding="8dp"
                    android:background="@drawable/bg_control_radius_shape"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/vehicle_condition"
                    android:textColor="#ff181818"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="16dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="10dp"
                    android:drawableEnd="@drawable/ic_enter_arrow"
                    android:drawableStart="@drawable/ic_main_control"/>

                <TextView
                    android:id="@+id/tvControl2"
                    android:drawablePadding="8dp"
                    android:background="@drawable/bg_control_radius_shape"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/vehicle_control"
                    android:textColor="#ff181818"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="16dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="10dp"
                    android:drawableEnd="@drawable/ic_enter_arrow"
                    android:drawableStart="@drawable/ic_main_control2"/>

                <TextView
                    android:id="@+id/tvShare"
                    android:drawablePadding="8dp"
                    android:background="@drawable/bg_share_radius_shape"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/share_key"
                    android:textColor="#ff181818"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="16dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="10dp"
                    android:drawableEnd="@drawable/ic_enter_arrow"
                    android:drawableStart="@drawable/ic_main_share"/>
            </LinearLayout>

        </RelativeLayout>




    </LinearLayout>
