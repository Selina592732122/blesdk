<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F8FB"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="设置"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:text="设置"
                android:layout_marginLeft="6dp"
                android:textColor="#e6000000"
                android:textSize="24sp"
                android:layout_marginTop="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_white_radius_shape"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/llAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:drawableStart="@drawable/ic_setting_account"
                    android:drawablePadding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_weight="1"
                    android:text="账号与安全"
                    android:textColor="#E6000000"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginRight="16dp"
                    android:src="@drawable/ic_enter_arrow" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/privacyLayout"
                android:background="?attr/selectableItemBackground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:drawableStart="@drawable/ic_setting_privacy"
                    android:drawablePadding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="16dp"
                    android:text="隐私政策"
                    android:textColor="#E6000000"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="16dp"
                    android:src="@drawable/ic_enter_arrow" />
            </LinearLayout>
            <LinearLayout
                android:visibility="gone"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/lawLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:drawableStart="@drawable/ic_setting_privacy2"
                    android:drawablePadding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="16dp"
                    android:text="车辆管理政策与法规"
                    android:textColor="#E6000000"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvSize"
                    android:text="111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="16dp"
                    android:src="@drawable/ic_enter_arrow" />
            </LinearLayout>


            <LinearLayout
                android:background="?attr/selectableItemBackground"
                android:id="@+id/uploadTerminalInfoLayout"
                android:layout_width="match_parent"
                android:gravity="center_vertical"
                android:layout_height="wrap_content"
                android:visibility="visible">

                <TextView
                    android:drawableStart="@drawable/ic_setting_privacy2"
                    android:drawablePadding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="上传设备信息"
                    android:padding="16dp"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginRight="16dp"
                    android:src="@drawable/ic_enter_arrow" />
            </LinearLayout>
        </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_radius_shape"
                android:orientation="vertical">

                <LinearLayout
                    android:background="?attr/selectableItemBackground"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:drawableStart="@drawable/ic_setting_version"
                        android:drawablePadding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="当前版本"
                        android:padding="16dp"
                        android:textColor="#E6000000"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/versionNameTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#99000000"
                        android:textSize="14sp"
                        android:layout_marginRight="16dp"
                        tools:text="1.0" />
                </LinearLayout>

                <LinearLayout
                    android:background="?attr/selectableItemBackground"
                    android:id="@+id/needUpgradeLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <TextView
                        android:drawableStart="@drawable/ic_setting_update"
                        android:drawablePadding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:text="检查版本更新"
                        android:textColor="#E6000000"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_marginRight="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_enter_arrow" />
                </LinearLayout>
                <LinearLayout
                    android:background="?attr/selectableItemBackground"
                    android:id="@+id/llCash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <TextView
                        android:drawableStart="@drawable/ic_setting_cash"
                        android:drawablePadding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:text="清除缓存"
                        android:textColor="#E6000000"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_marginRight="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_enter_arrow" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_radius_shape"
                android:orientation="vertical">

                <LinearLayout
                    android:visibility="gone"
                    android:id="@+id/feedbackLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:text="反馈与投诉"
                        android:textColor="#E6000000"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="12dp"
                        android:src="@drawable/ic_enter_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:background="?attr/selectableItemBackground"
                    android:visibility="visible"
                    android:id="@+id/cancellationLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:drawableStart="@drawable/ic_setting_update"
                        android:drawablePadding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:text="注销账号"
                        android:textColor="#E6000000"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="12dp"
                        android:src="@drawable/ic_enter_arrow" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="退出登录"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:padding="17dp"
                android:textColor="#99000000"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_gray_04_radius_shape"
                android:textSize="14sp"
                android:textStyle="bold" />


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>




</LinearLayout>