<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_white_radius_shape"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/title"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="蓝牙参数设置"
                android:textColor="#ff181818"
                android:layout_centerInParent="true"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textColor="#ff181818"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="数值越大，代表启动/关锁距离越远"
            android:textColor="#ff005bbc"
            android:textSize="12sp"
            android:gravity="center"/>
        <LinearLayout
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">



            <Switch
                android:id="@+id/switchPKE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:switchMinWidth="20dp"
                android:textOff=""
                android:checked="false"
                android:textOn=""
                android:text="PKE开关"
                android:thumb="@drawable/selector_switch_thumb"
                android:track="@drawable/selector_switch_track"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

        </LinearLayout>


        <LinearLayout
            android:orientation="vertical"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:background="@drawable/bg_gray_personal_radius_shape"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史启动值："
                android:textColor="#cc000000"
                android:textSize="12sp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="8dp"/>

            <LinearLayout
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="20dp"
                    android:text="当前启动值："
                    android:textColor="#cc000000"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/tvMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#ff181818"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConfirmTop"
                android:text="确认"
                android:enabled="true"
                android:visibility="gone"
                android:textColor="@color/bluetooth_btn_select"
                android:background="@drawable/selector_scan_btn"
                android:layout_marginLeft="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <View
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="#1A000000"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>

            <TextView
                android:id="@+id/tvBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史关锁值："
                android:textColor="#cc000000"
                android:textSize="12sp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="8dp"/>
            <LinearLayout
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="20dp"
                    android:text="当前关锁值："
                    android:textColor="#cc000000"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/tvMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#ff181818"
                    android:textSize="14sp"
                    />
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnConfirmBottom"
                android:text="确认"
                android:enabled="true"
                android:textColor="@color/bluetooth_btn_select"
                android:background="@drawable/selector_scan_btn"
                android:layout_marginLeft="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:visibility="gone"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:gravity="center_vertical"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="配对成功后可选择档位"
                android:textColor="#99000000"
                android:textSize="12sp"
                />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPair"
                android:layout_width="wrap_content"
                android:background="@drawable/bg_radius_shape_no_pair"
                android:layout_height="30dp"
                tools:text="未配对"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/white"/>
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_gravity="center_vertical"
                android:layout_height="20dp"
                android:layout_centerInParent="true"
                android:indeterminateTint="@color/purple_500"
                android:visibility="gone" />

        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:layout_marginLeft="16dp">

            <LinearLayout
                android:id="@+id/llGear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:background="@drawable/bg_tooth_gear_unselect"
                    android:layout_marginRight="8dp"
                    android:id="@+id/blue_tooth_weak"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/gear_weak_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/gear_weak"
                        android:textColor="#99000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/gear_connect_weak_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/connect_1m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/gear_disconnect_weak_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:layout_marginBottom="20dp"
                        android:text="@string/disconnect_3m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />


                </LinearLayout>
                <RelativeLayout
                    android:layout_marginRight="8dp"
                    android:background="@drawable/bg_tooth_gear_unselect"
                    android:id="@+id/blue_tooth_middle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    >
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentLeft="true"
                        android:background="@drawable/ic_blue_tooth_gear_recommend"
                        />

                    <TextView
                        android:layout_centerHorizontal="true"
                        android:id="@+id/gear_mid_text"
                        android:layout_alignParentTop="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/gear_mid"
                        android:textColor="#99000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/gear_connect_middle_value"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@+id/gear_mid_text"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connect_2m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/gear_disconnect_middle_value"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@+id/gear_connect_middle_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:layout_marginBottom="20dp"
                        android:text="@string/disconnect_5m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />



                </RelativeLayout>

                <LinearLayout
                    android:background="@drawable/bg_tooth_gear_unselect"
                    android:id="@+id/blue_tooth_strong"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/gear_strong_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/gear_strong"
                        android:textColor="#99000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                    <TextView
                        android:id="@+id/gear_connect_strong_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/connect_5m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/gear_disconnect_strong_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:layout_marginBottom="20dp"
                        android:text="@string/disconnect_10m"
                        android:textColor="#99000000"
                        android:textSize="13sp" />


                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/viewMask"
                android:layout_alignTop="@+id/llGear"
                android:layout_alignBottom="@+id/llGear"
                android:layout_width="match_parent"
                android:background="#aaffffff"
                android:layout_height="wrap_content"/>
        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirm"
            android:text="确认"
            android:enabled="false"
            android:textColor="@color/white"
            android:background="@drawable/selector_scan_btn"
            android:layout_marginLeft="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="16dp"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>