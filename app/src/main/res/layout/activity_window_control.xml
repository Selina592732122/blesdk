<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF6F6F8"
    android:orientation="vertical">

    <View
        android:id="@+id/statusBarView"
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <ImageView
        android:id="@+id/ivBg"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_window"/>

    <RelativeLayout
        android:layout_below="@+id/statusBarView"
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="车窗控制"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_marginBottom="7dp"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:gravity="center_horizontal"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="15dp"
                android:layout_marginRight="13dp"
                android:orientation="vertical"
                android:background="@drawable/bg_white_radius12_shape"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="左前窗"
                    android:textColor="#2C3E51"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/llLeftClose"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:rotation="180"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="关"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llLeftOpen"
                    android:layout_marginTop="18dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="开"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="15dp"
                android:orientation="vertical"
                android:background="@drawable/bg_white_radius12_shape"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="右前窗"
                    android:textColor="#2C3E51"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/llRightClose"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:rotation="180"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="关"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llRightOpen"
                    android:layout_marginTop="18dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="开"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:visibility="gone"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:gravity="center_horizontal"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="15dp"
                android:layout_marginRight="13dp"
                android:orientation="vertical"
                android:background="@drawable/bg_white_radius12_shape"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="左后窗"
                    android:textColor="#2C3E51"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:rotation="180"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="关"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="18dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="开"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="15dp"
                android:orientation="vertical"
                android:background="@drawable/bg_white_radius12_shape"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="右后窗"
                    android:textColor="#2C3E51"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:rotation="180"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="关"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="18dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="56dp"
                    android:background="@drawable/bg_circle_white"
                    android:backgroundTint="#F1F5F9"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="56dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_arrow_gray_down"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="开"
                        android:textColor="#4A5A6D"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llBtn"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:gravity="center"
            android:layout_height="wrap_content">
            <LinearLayout
                android:id="@+id/tvBtnClose"
                android:layout_width="0dp"
                android:background="@drawable/bg_blue_ok_radius_shape"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:backgroundTint="#09B66E"
                android:layout_marginRight="7dp"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="车窗全关"
                    android:drawablePadding="10dp"
                    android:textColor="#ffffffff"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:gravity="center"
                    android:drawableStart="@drawable/ic_win_close"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/tvBtnOpen"
                android:layout_width="0dp"
                android:background="@drawable/bg_blue_ok_radius_shape"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:backgroundTint="#1C81F2"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:text="车窗全开"
                    android:drawablePadding="10dp"
                    android:textColor="#ffffffff"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:gravity="center"
                    android:drawableStart="@drawable/ic_win_open"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

</RelativeLayout>