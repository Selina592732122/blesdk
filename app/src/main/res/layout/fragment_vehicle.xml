                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/statusBarView"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="11dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="11dp"
                android:singleLine="true"
                android:text="@string/experience_mode"
                android:padding="8dp"
                android:gravity="center_vertical|center_horizontal"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/restPowerLayout"
                android:layout_below="@+id/verticalNameTv"
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="15dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:id="@+id/batteryPercentLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp">

                    <TextView
                        android:id="@+id/batteryPercentTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        tools:text="72" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="%"
                        android:textColor="#FFFFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.akexorcist.roundcornerprogressbar.RoundCornerProgressBar
                    android:id="@+id/batteryRoundPb"
                    android:layout_width="84dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    app:rcBackgroundColor="#FFF2F2F2"
                    app:rcBackgroundPadding="0dp"
                    app:rcMax="100"
                    app:rcProgressColors="@array/progress_gradient_colors"
                    app:rcRadius="20dp" />
                <!--                app:rcProgressColor="#2cd962"-->

                <LinearLayout
                    android:id="@+id/powerLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voltage"
                        android:textColor="#FFFFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/powerTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textColor="#FFFFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="64.68v" />
                </LinearLayout>


            </LinearLayout>

            <ImageView
