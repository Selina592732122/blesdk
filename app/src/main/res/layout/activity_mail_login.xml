<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFF7F8FB"
    android:orientation="vertical">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_login" />

    <LinearLayout
        android:id="@+id/llTitle"
        android:layout_marginTop="44dp"
        android:layout_width="match_parent"
        android:gravity="center_vertical"
        android:layout_height="44dp">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:src="@drawable/ic_back_white"/>
    </LinearLayout>

    <LinearLayout
        android:layout_below="@+id/llTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_marginTop="44dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_password_login"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textColor="#ffffffff"
            android:textSize="24sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="28dp"
            android:layout_marginTop="48dp"
            android:layout_marginRight="28dp"
            android:background="@drawable/bg_gray_radius_shape"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/userNameEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@null"
                android:hint="@string/enter_email_address"
                android:inputType="textEmailAddress"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:singleLine="true"
                android:textColor="#ffffff"
                android:textColorHint="#ffffff"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="28dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="28dp"
            android:background="@drawable/bg_gray_radius_shape"
            android:gravity="center_vertical"
            android:orientation="horizontal">

<!--            <androidx.appcompat.widget.AppCompatEditText-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginLeft="10dp"-->
<!--                android:layout_weight="1"-->
<!--                android:background="@null"-->
<!--                -->
<!--                android:inputType="number"-->
<!--                android:paddingTop="18dp"-->
<!--                android:paddingBottom="18dp"-->
<!--                android:singleLine="true"-->
<!--                android:textColor="@color/white"-->
<!--                android:textColorHint="#ffffff"-->
<!--                android:textSize="14sp" />-->

            <com.shenghao.widget.PasswordEditText
                android:id="@+id/etPwd"
                android:layout_width="match_parent"
                app:hint="@string/enter_password"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                app:background="@color/transparent"
                app:textColorHint="#ffffff"
                app:textColor="@color/white"
                android:layout_height="wrap_content"/>

        </LinearLayout>
        <TextView
            android:id="@+id/tvForget"
            android:layout_width="303dp"
            android:layout_height="17dp"
            android:text="@string/forgot_password"
            android:textColor="#ffffffff"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="28dp"/>

        <TextView
            android:id="@+id/loginBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="40dp"
            android:layout_marginRight="25dp"
            android:background="@drawable/selector_login_btn"
            android:gravity="center"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:text="@string/login"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="14dp"
            android:layout_marginRight="25dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/agreementCb"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_off" />

            <TextView
                android:id="@+id/privacyTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:text="@string/agree_privacy2"
                android:textColor="#99ffffff"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <View
                android:layout_width="92dp"
                android:layout_height="1dp"
                android:background="#33ffffff"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            android:text="@string/other_login_methods"
                android:textColor="#8cffffff"
                android:textSize="12sp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"/>
            <View
                android:layout_width="92dp"
                android:layout_height="1dp"
                android:background="#33ffffff"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivChat"
                android:layout_width="wrap_content"
                android:src="@drawable/ic_login_wechat"
                android:layout_marginRight="24dp"
                android:layout_height="wrap_content"/>
            <ImageView
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_margin="24dp"
                android:src="@drawable/ic_login_qq"
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/ivCall"
                android:layout_width="wrap_content"
                android:src="@drawable/ic_login_call"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>