<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F8FB"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

                <TextView
                    android:id="@+id/titleNameTv"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/add_geofence"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.amap.api.maps.MapView
            android:id="@+id/geoFenceMapView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-25dp"
            android:background="@drawable/bg_white_radius_shape2"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/geofence_range"
                android:layout_gravity="center"
                android:textColor="#99000000"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/currentRadiusTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E6000000"
                android:layout_gravity="center"
                android:textSize="24sp"
                android:layout_marginTop="2dp"
                android:textStyle="bold"
                tools:text="3500m" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center_vertical"
                android:paddingLeft="45dp"
                android:paddingRight="45dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/radius_min"
                    android:textColor="#99000000"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/radiusSeekBar"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:maxHeight="12dp"
                    android:minHeight="12dp"
                    android:progress="20"
                    android:progressDrawable="@drawable/layer_geofence_seekbar"
                    android:splitTrack="false"
                    android:thumb="@drawable/drawable_thumb_blue" />
                <!--                android:paddingStart="0dp"-->
                <!--                android:paddingEnd="0dp"-->
                <!--                android:thumbOffset="0dp"-->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10000m"
                    android:textColor="#99000000"
                    android:textSize="12sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginLeft="28dp"
                android:layout_marginRight="28dp"
                android:background="#1A000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="28dp"
                android:gravity="center_vertical"
                android:layout_marginRight="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/geofence_center"
                    android:textColor="#FF181818"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/geofence_center_hint"
                    android:textColor="#99000000"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/centerPointTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="28dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="28dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#E6000000"
                android:textSize="14sp" />

                <TextView
                    android:id="@+id/nextStepTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_marginLeft="28dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginRight="28dp"
                    android:background="@drawable/bg_blue_ok_radius_shape"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="@string/next_step"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>