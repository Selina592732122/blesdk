<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_control_radius0_shape"
    android:orientation="vertical">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_charge"/>

    <View
        android:id="@+id/statusBarView"
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <RelativeLayout
        android:layout_below="@+id/statusBarView"
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/scheduled_charging"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_below="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_marginTop="92dp"
        android:orientation="vertical"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:paddingLeft="13dp"
            android:paddingRight="13dp"
            android:paddingTop="18dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            android:paddingBottom="18dp"
            android:background="@drawable/bg_white_radius8_shape"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/scheduled_charging"
                android:textColor="#cc000000"
                android:textSize="14sp"
                android:gravity="center_vertical"
                android:drawablePadding="8dp" />

            <Switch
                android:id="@+id/switchChong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:switchMinWidth="20dp"
                android:textOff=""
                android:checked="true"
                android:textOn=""
                android:thumb="@drawable/selector_switch_thumb"
                android:track="@drawable/selector_switch_track"
                tools:ignore="UseSwitchCompatOrMaterialXml" />
            
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:paddingLeft="13dp"
            android:paddingRight="13dp"
            android:paddingTop="18dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:paddingBottom="18dp"
            android:background="@drawable/bg_white_radius8_shape"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/charging_time"
                android:textColor="#cc000000"
                android:textSize="14sp"
                android:gravity="center_vertical"
                android:drawablePadding="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="#1A000000"/>

            <LinearLayout
                android:id="@+id/llStart"
                android:background="@drawable/bg_dialog_edit"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:text="@string/start_time"
                    android:textColor="#99000000"
                    android:textSize="12sp"
                    android:id="@+id/tvStart"/>
                <TextView
                    android:id="@+id/tvTimeStart"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_time"
                    android:layout_marginLeft="12dp"
                    android:textColor="#cc000000"
                    android:textSize="14sp"
                    android:drawableEnd="@drawable/ic_enter_arrow"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/llEnd"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_dialog_edit"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:text="@string/end_time"
                    android:textColor="#99000000"
                    android:textSize="12sp"
                    android:id="@+id/tvEnd"/>

                <TextView
                    android:id="@+id/tvTimeEnd"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/next_day_time"
                    android:layout_marginLeft="12dp"
                    android:textColor="#cc000000"
                    android:textSize="14sp"
                    android:drawableEnd="@drawable/ic_enter_arrow"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>