<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_round_white"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivTop"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_dialog_top01"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:textColor="#FF181818"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="@string/dialog_title" />

        <TextView
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="10dp"
            android:textColor="#333333"
            android:lineSpacingExtra="3dp"
            tools:text="@string/dialog_content"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/contentEtLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_dialog_edit"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/contentEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:background="@color/transparent"
                android:singleLine="true"
                android:textColor="#FF181818"
                android:textColorHint="#66000000"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1px" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cancelTv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1.0"
                android:background="@drawable/bg_gray_cancel_radius_shape"
                android:gravity="center"
                android:text="@string/dialog_cancel"
                android:textColor="#99000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/submitTv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="12dp"
                android:layout_weight="1.0"
                android:background="@drawable/bg_blue_ok_radius_shape"
                android:gravity="center"
            android:text="@string/dialog_ok"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
    <ImageView
        android:id="@+id/ivBg"
        android:src="@drawable/ic_dialog_bg_blue"
        android:layout_width="match_parent"
        android:scaleType="fitXY"
        android:layout_height="wrap_content"/>
</RelativeLayout>
