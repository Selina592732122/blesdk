<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFF7F8FB"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_title_back"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/bluetooth_binding" />
        <TextView
            android:id="@+id/tvDemo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_centerVertical="true"
            android:text="demo" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/discover_devices"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:textColor="#ff181818"
                android:padding="16dp"
                android:textSize="16sp"/>
            <RelativeLayout
                android:id="@+id/rlScan"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:id="@+id/radarView"
                    android:layout_centerHorizontal="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivBleBg"
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_ble_background"
                        android:layout_height="wrap_content"/>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_ble_forground"/>

                </RelativeLayout>


                <TextView
                    android:layout_below="@+id/radarView"
                    android:id="@+id/tvScanning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="64dp"
                    android:text="@string/scanning_nearby_devices"
                    android:textColor="#e6000000"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:text="@string/stay_close_during_search"
                    android:textColor="#99000000"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:layout_marginBottom="24dp"
                    android:layout_below="@+id/tvScanning"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/llFind"
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                    <com.shenghao.blesdkdemo.widget.EmptyRecyclerView
                        android:id="@+id/recyclerViewFind"
                        android:background="@drawable/bg_white_radius_shape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:drawableTop="@drawable/ic_scan_empty"
                        android:id="@+id/tvEmptyFind"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                android:text="@string/no_devices_found"
                        android:textColor="#99000000"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>


            <TextView
                android:id="@+id/tvScan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tvHint"
                android:layout_gravity="center_horizontal"
                android:text="@string/rediscover_devices"
                android:layout_centerHorizontal="true"
                android:textColor="#ffffffff"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:enabled="false"
                android:paddingLeft="45dp"
                android:paddingRight="45dp"
                android:background="@drawable/selector_scan_btn"/>

            <TextView
                android:id="@+id/tvTitle2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bound_devices"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:textColor="#ff181818"
                android:textSize="16sp"
                android:padding="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_height="wrap_content">
                <com.shenghao.blesdkdemo.widget.EmptyRecyclerView
                    android:id="@+id/recyclerViewBind"
                    android:background="@drawable/bg_white_radius_shape"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:drawableTop="@drawable/ic_scan_empty"
                    android:id="@+id/tvEmptyBind"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                android:text="@string/no_devices_found"
                    android:textColor="#99000000"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>



</LinearLayout>