        <activity android:name=".ui.EditGeoFencePolygonActivity" />
        <activity android:name=".ui.NoticeCenterActivity" />
        <activity android:name=".ui.NoticeDetailActivity" />
        <activity android:name=".ui.AlarmSettingActivity" />
        <activity android:name=".ui.PayServiceActivity" />
        <activity android:name=".ui.AccountManageActivity" />
        <activity android:name=".ui.BindMailActivity" />
        <activity android:name=".ui.BindPhoneActivity" />
        <activity android:name=".ui.WxBindPhoneActivity">
        </activity>
        <activity android:name=".ui.SettingPasswordActivity" />
        <activity android:name=".ui.FindPasswordActivity" />
        <activity android:name=".ui.MailLoginActivity" />
        <activity android:name=".ui.BatteryActivity" />
        <activity android:name=".ui.KeyActivity" />
        <activity android:name=".ui.OneKeyActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout">
        </activity>
        <activity android:name=".ui.OneKeyPortraitActivity"/>
        <activity android:name=".ui.Control2Activity" />
