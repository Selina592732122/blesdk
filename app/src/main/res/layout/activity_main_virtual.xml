<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/main_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/llBottom"
        android:background="#fff6f6f8"
        android:layout_weight="1" />

    <ImageView
        android:visibility="visible"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="14dp"
        android:layout_alignParentBottom="true"
        android:layout_width="54dp"
        android:background="@drawable/bg_circle_white"
        android:padding="10dp"
        android:layout_height="54dp"/>

    <LinearLayout
        android:id="@+id/llBottom"
        android:layout_alignParentBottom="true"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ededed" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="5dp">

            <LinearLayout
                android:id="@+id/vehicleTabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/vehicleTabIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_home_selected" />

                <TextView
                    android:id="@+id/vehicleTabTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/my_vehicle"
                    android:textColor="@color/main_tab_selected"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/controlTabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:padding="1dp"
                    android:id="@+id/controlTabIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_control_unselected" />

                <TextView
                    android:id="@+id/controlTabTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/vehicle_control"
                    android:textColor="@color/main_tab_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:padding="1dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/main_tab_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- //TODO superLT 暂时隐藏商城tab -->
            <LinearLayout
                android:visibility="visible"
                android:id="@+id/msgTabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:padding="1dp"
                    android:id="@+id/storeTabIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_msg_unselected" />

                <TextView
                    android:id="@+id/msgTabTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/mall"
                    android:textColor="@color/main_tab_unselected"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/myTabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:padding="1dp"
                    android:id="@+id/myTabIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_my_unselected" />

                <TextView
                    android:id="@+id/myTabTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/settings"
                    android:textColor="@color/main_tab_unselected"
                    android:textSize="12sp" />
            </LinearLayout>



        </LinearLayout>
    </LinearLayout>


    <ImageView
        android:visibility="visible"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="12dp"
        android:layout_width="54dp"
        android:layout_alignParentBottom="true"
        android:padding="10dp"
        android:src="@drawable/logo_black"
        android:layout_height="54dp"
        android:background="@drawable/bg_circle_white_without_stroke"/>

</RelativeLayout>