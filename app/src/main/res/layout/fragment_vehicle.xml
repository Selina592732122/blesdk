                        android:layout_marginRight="16dp"
                        app:cardElevation="0dp"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/ridingDataLayout"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:background="@drawable/ic_main_ride_bg">

                            <LinearLayout
                                android:gravity="top"
                                android:layout_width="match_parent"
                                android:layout_weight="1"
                                android:layout_height="0dp">

                                <TextView
                                    android:id="@+id/ridingDataTv"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:text="@string/riding_records"
                                    android:drawablePadding="4dp"
                                    android:layout_weight="1"
                                    android:textColor="#ff181818"
                                    android:gravity="center_vertical"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:drawableEnd="@drawable/ic_enter_arrow"
                                    app:drawableStartCompat="@drawable/ic_ride_record" />

                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/sumRidingDistanceLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="13dp"
                                android:layout_marginRight="0dp"
                                android:orientation="vertical"
                                android:visibility="visible">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:id="@+id/sumRidingDistanceTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="231.4"
                                        android:textColor="#FF181818"
                                        android:textSize="30sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="2dp"
                                        android:text="km"
                                        android:textColor="#FF181818"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_mileage"
                                    android:textColor="#99000000"
                                    android:textSize="11sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:id="@+id/tvLastDistance"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0.0"
                                        android:textColor="#FF181818"
                                        android:textSize="18sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="2dp"
                                        android:text="km"
                                        android:textColor="#FF181818"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
