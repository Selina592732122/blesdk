<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical">

    <ImageView
        android:layout_width="match_parent"
        android:src="@drawable/bg_one_key_large2"
        android:scaleType="centerCrop"
        android:layout_height="match_parent"/>

    <View
        android:id="@+id/statusBarView"
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <RelativeLayout
        android:visibility="visible"
        android:layout_below="@+id/statusBarView"
        android:id="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/titleBackBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:padding="10dp"
            android:src="@drawable/ic_back_white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="掌上挪车"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:orientation="vertical"
        android:layout_below="@+id/titleLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RadioGroup
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="16dp"
            android:checkedButton="@id/rb1"
            android:layout_marginRight="16dp"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/rb1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:background="@drawable/selector_gear_one"
                android:button="@null"
                android:drawableStart="@drawable/ic_gear_one"
                android:textColor="@color/txt_gear_one"
                android:text="1档"
                android:paddingLeft="22dp"
                android:paddingRight="22dp"
                android:gravity="center"
                android:drawableTint="@color/txt_gear_one"
                android:layout_height="wrap_content"/>
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/rb2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:background="@drawable/selector_gear_two"
                android:button="@null"
                android:paddingLeft="22dp"
                android:paddingRight="22dp"
                android:gravity="center"
                android:drawableStart="@drawable/ic_gear_two"
                android:textColor="@color/txt_gear_two"
                android:drawableTint="@color/txt_gear_two"
                android:text="2档"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:layout_height="wrap_content"/>
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/rb3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:background="@drawable/selector_gear_three"
                android:button="@null"
                android:paddingLeft="22dp"
                android:paddingRight="22dp"
                android:gravity="center"
                android:drawableStart="@drawable/ic_gear_three"
                android:textColor="@color/txt_gear_three"
                android:drawableTint="@color/txt_gear_three"
                android:text="3档"
                android:layout_height="wrap_content"/>
        </RadioGroup>



        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvHint"
                android:layout_centerHorizontal="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请保持安全距离，注意周围环境"
                android:textColor="#99ffffff"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                android:layout_gravity="center"/>

            <LinearLayout
                android:layout_marginTop="24dp"
                android:visibility="invisible"
                android:layout_centerHorizontal="true"
                android:id="@+id/llMoving"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:gravity="center_vertical"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivMoving"
                    android:layout_width="wrap_content"
                    android:src="@drawable/ic_nuo_che_circle"
                    android:layout_marginRight="3dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvMoving"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="车辆后退中，松手可暂停"
                        android:textColor="#ffffffff"
                        android:textSize="14sp"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="请保持安全距离，注意周围环境"
                        android:textColor="#99ffffff"
                        android:textSize="12sp"
                        />

                </LinearLayout>


            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_below="@+id/llMoving"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/ivTrack"
                    android:layout_width="wrap_content"
                    android:src="@drawable/bg_track_car"
                    android:layout_centerInParent="true"
                    android:layout_height="wrap_content"/>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_center_car"
                        android:paddingLeft="5dp"
                        android:layout_centerInParent="true"
                        android:layout_height="wrap_content"/>

                    <ImageView
                        android:id="@+id/ivStop"
                        android:layout_width="wrap_content"
                        android:src="@drawable/ic_stop"
                        android:layout_centerInParent="true"
                        android:layout_height="wrap_content"/>

                </RelativeLayout>

                <com.shenghao.blesdkdemo.widget.LongPressImageView
                    android:id="@+id/ivUp"
                    android:layout_width="wrap_content"
                    android:src="@drawable/ic_up"
                    android:layout_marginTop="10dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignTop="@+id/ivTrack"
                    android:layout_height="wrap_content"/>

                <com.shenghao.blesdkdemo.widget.LongPressImageView
                    android:id="@+id/ivDown"
                    android:layout_width="wrap_content"
                    android:src="@drawable/ic_down"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="10dp"
                    android:layout_alignBottom="@+id/ivTrack"
                    android:layout_height="wrap_content"/>

            </RelativeLayout>




        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>