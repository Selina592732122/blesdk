                            android:background="@drawable/bg_gray_03_radius_shape"
                            android:padding="16dp"
                            android:orientation="vertical"
                            android:layout_weight="1">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                            android:text="@string/ebs_selection"
                                    android:textStyle="bold"
                                    android:textColor="#99000000"
                                    android:textSize="14sp"/>
                                <Switch
                                    android:id="@+id/switchEBS"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:switchMinWidth="20dp"
                                    android:textOff=""
                                    android:textOn=""
                                    android:thumb="@drawable/selector_switch_thumb_yellow"
                                    android:track="@drawable/selector_switch_track_yellow"
                                    tools:ignore="UseSwitchCompatOrMaterialXml" />

                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvEBS"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/off"
                                android:textColor="#ff181818"
                                android:textSize="20sp"
                                android:layout_marginTop="15dp"/>

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="11dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_gray_03_radius_shape"
                            android:padding="16dp"
                            android:layout_marginRight="16dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="@string/cruise_selection"
                                    android:textStyle="bold"
                                    android:textColor="#99000000"
                                    android:textSize="14sp"/>
                                <Switch
                                    android:id="@+id/switchXun"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:switchMinWidth="20dp"
                                    android:textOff=""
                                    android:checked="true"
                                    android:textOn=""
                                    android:thumb="@drawable/selector_switch_thumb_yellow"
                                    android:track="@drawable/selector_switch_track_yellow"
                                    tools:ignore="UseSwitchCompatOrMaterialXml" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvXun"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/on"
                                android:textColor="#17cbbc"
                                android:textSize="20sp"
                                android:layout_marginTop="15dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_gray_03_radius_shape"
                            android:padding="16dp"
                            android:orientation="vertical"
                            android:layout_weight="1">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="@string/current_limit_setting"
                                    android:textStyle="bold"
                                    android:textColor="#99000000"
                                    android:textSize="14sp"/>
                                <Switch
                                    android:id="@+id/switchXian"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:switchMinWidth="20dp"
                                    android:textOff=""
                                    android:textOn=""
                                    android:thumb="@drawable/selector_switch_thumb_yellow"
                                    android:track="@drawable/selector_switch_track_yellow"
                                    tools:ignore="UseSwitchCompatOrMaterialXml" />

                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvXian"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/off"
                                android:textColor="#ff181818"
                                android:textSize="20sp"
                                android:layout_marginTop="15dp"/>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="15dp"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvMode"
            android:background="@drawable/bg_black_radius_shape2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginRight="7dp"
            android:padding="12dp"
            android:gravity="center"
            android:text="@string/mode_adjust"
            android:textColor="#FF1A1A1A"
            android:textSize="14sp"/>
        <TextView
            android:id="@+id/tvRecover"
            android:background="@drawable/bg_black_radius_shape"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:text="@string/factory_reset"
            android:textColor="#ffffffff"
            android:textSize="14sp"/>
    </LinearLayout>


</RelativeLayout>